PORT=3000

# Pick one search key. SEARCH_PROVIDER can be "tavily", "brave", or omitted for auto-detect.
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=

# Use a free OpenRouter model id, for example a model ending in ":free".
# Qwen/DeepSeek-class instruct models tend to be more faithful at literal text extraction
# than small Gemma variants. Check https://openrouter.ai/models?max_price=0 for current options.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MAX_TOKENS=2000

# Optional OpenRouter attribution headers.
APP_URL=http://localhost:3000
APP_NAME=Adapt
